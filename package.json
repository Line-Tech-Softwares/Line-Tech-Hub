{
  "name": "line-tech-hub",
  "version": "0.1.0",
  "description": "Line Tech Softwares Desktop App - Job Management & PDF Studio",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "author": "Line Tech Softwares",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron-dev": "wait-on http://localhost:5173 && electron .",
    "dev:all": "concurrently \"npm run dev\" \"npm run electron-dev\"",
    "build:electron": "tsc -p electron/tsconfig.json && vite build && electron-builder",
    "dist": "npm run build:electron",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "firebase": "^10.7.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-store": "^8.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.linetechsoftwares.hub",
    "productName": "Line Tech Hub",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/node_modules/**"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
